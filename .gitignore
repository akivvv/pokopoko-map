# OS
Thumbs.db
.DS_Store

# エディタ
.vscode/
.idea/

# 秘匿情報(認証サーバー等で使用。絶対にコミットしない)
.env
.env.*
*.serviceAccountKey.json
*-firebase-adminsdk-*.json

# ビルド成果物・依存物(Vite等の導入後)
node_modules/
dist/
.vite/

# 注: firebase-config.js(フロント用Firebase Web SDK設定)は意図的に対象外。
#     Firebase Web SDKの設定値は非秘匿情報のため追跡対象のまま(docs/SPEC.md §13.4)。
