{
	"permissions": {
		"allow": [
			"Bash(npm run *)",
			"Bash(npm ci)",
			"Bash(npx biome *)",
			"Bash(npx vitest *)",
			"Bash(git status)",
			"Bash(git status *)",
			"Bash(git diff *)",
			"Bash(git log *)",
			"Bash(git add *)",
			"Bash(git commit *)",
			"Bash(git branch)",
			"Bash(git branch -v*)",
			"Bash(git checkout -b *)",
			"Bash(git switch *)",
			"Bash(git fetch*)",
			"Bash(git reset --hard*)",
			"Bash(git pull*)",
			"Bash(git checkout -- *)",
			"Bash(git checkout .)"
		],
		"ask": [
			"Bash(git merge *)",
			"Bash(git rebase *)",
			"Bash(git push*)",
			"Bash(git branch -d*)",
			"Bash(git branch -D*)",
			"Bash(git clean *)"
		],
		"deny": [
			"Bash(sudo *)",
			"Bash(rm -rf *)",
			"Read(~/.ssh/**)",
			"Bash(git push --force*)",
			"Bash(git push -f*)",
			"Bash(git branch -D main)",
			"Bash(git branch -D master)"
		]
	},
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "node \".claude/hooks/lint-on-write.cjs\"",
						"statusMessage": "Biomeでlint中...",
						"timeout": 30
					}
				]
			}
		]
	}
}
