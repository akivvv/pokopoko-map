{
	"permissions": {
		"allow": [
			"Edit(.claude/agents/**)",
			"Write(.claude/agents/**)",
			"Bash(npm run:*)",
			"Bash(npm run *)",
			"Bash(npm ci)",
			"Bash(npx biome:*)",
			"Bash(npx biome *)",
			"Bash(npx vitest:*)",
			"Bash(npx vitest *)",
			"Bash(git status)",
			"Bash(git status:*)",
			"Bash(git status *)",
			"Bash(git diff:*)",
			"Bash(git diff *)",
			"Bash(git log:*)",
			"Bash(git log *)",
			"Bash(git add:*)",
			"Bash(git add *)",
			"Bash(git commit:*)",
			"Bash(git commit *)",
			"Bash(git branch)",
			"Bash(git branch -v:*)",
			"Bash(git branch -v*)",
			"Bash(git checkout -b:*)",
			"Bash(git checkout -b *)",
			"Bash(git switch:*)",
			"Bash(git switch *)",
			"Bash(git fetch:*)",
			"Bash(git fetch*)",
			"Bash(git reset --hard:*)",
			"Bash(git reset --hard*)",
			"Bash(git pull:*)",
			"Bash(git pull*)",
			"Bash(git checkout --:*)",
			"Bash(git checkout -- *)",
			"Bash(git checkout .)",
			"Bash(git show:*)",
			"Bash(git show *)",
			"Bash(git rev-parse:*)",
			"Bash(git rev-parse *)",
			"Bash(tail:*)",
			"Bash(tail *)",
			"Bash(head:*)",
			"Bash(head *)",
			"Bash(grep:*)",
			"Bash(grep *)",
			"Bash(sed -n:*)",
			"Bash(sed -n *)",
			"Bash(sort:*)",
			"Bash(sort *)",
			"Bash(uniq:*)",
			"Bash(uniq *)",
			"Bash(wc:*)",
			"Bash(wc *)",
			"Bash(cat:*)",
			"Bash(cat *)",
			"Bash(ls)",
			"Bash(ls:*)",
			"Bash(ls *)",
			"Bash(find:*)",
			"Bash(find *)",
			"Bash(echo:*)",
			"Bash(echo *)",
			"Bash(node --version)",
			"Bash(node -e:*)",
			"Bash(curl -s https://api.github.com/repos/akivvv/pokopoko-map/:*)",
			"Bash(curl -s https://api.github.com/repos/akivvv/pokopoko-map/*)"
		],
		"ask": [
			"Bash(git merge:*)",
			"Bash(git merge *)",
			"Bash(git rebase:*)",
			"Bash(git rebase *)",
			"Bash(git push:*)",
			"Bash(git push*)",
			"Bash(git branch -d:*)",
			"Bash(git branch -d*)",
			"Bash(git branch -D:*)",
			"Bash(git branch -D*)",
			"Bash(git clean:*)",
			"Bash(git clean *)"
		],
		"deny": [
			"Bash(sudo:*)",
			"Bash(sudo *)",
			"Bash(rm -rf:*)",
			"Bash(rm -rf *)",
			"Read(~/.ssh/**)",
			"Bash(git push --force:*)",
			"Bash(git push --force*)",
			"Bash(git push -f:*)",
			"Bash(git push -f*)",
			"Bash(git branch -D main)",
			"Bash(git branch -D master)"
		]
	},
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "node \".claude/hooks/lint-on-write.cjs\"",
						"statusMessage": "Biomeでlint中...",
						"timeout": 30
					}
				]
			}
		]
	}
}
